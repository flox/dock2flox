#!/usr/bin/env bash
# dock2flox — Convert Dockerfiles and Compose files to Flox environments
# Usage: dock2flox [OPTIONS] [FILE...]

set -euo pipefail

# Resolve script location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOCK2FLOX_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source libraries
source "$DOCK2FLOX_ROOT/lib/core.sh"
source "$DOCK2FLOX_ROOT/lib/mapper_packages.sh"
source "$DOCK2FLOX_ROOT/lib/mapper_base_images.sh"
source "$DOCK2FLOX_ROOT/lib/run_shell_interpreter.sh"
source "$DOCK2FLOX_ROOT/lib/parser_dockerfile.sh"
source "$DOCK2FLOX_ROOT/lib/emitter_toml.sh"

# Check for optional modules
if [[ -f "$DOCK2FLOX_ROOT/lib/parser_compose.sh" ]]; then
    source "$DOCK2FLOX_ROOT/lib/parser_compose.sh"
fi
if [[ -f "$DOCK2FLOX_ROOT/lib/validator.sh" ]]; then
    source "$DOCK2FLOX_ROOT/lib/validator.sh"
fi
if [[ -f "$DOCK2FLOX_ROOT/lib/parser_devcontainer.sh" ]]; then
    source "$DOCK2FLOX_ROOT/lib/parser_devcontainer.sh"
fi

# --- CLI Argument Parsing ---

usage() {
    cat <<EOF
dock2flox v${DOCK2FLOX_VERSION} — Convert Dockerfiles to Flox environments

USAGE:
    dock2flox [OPTIONS] [FILE...]

OPTIONS:
    -i, --input FILE        Explicit input file (repeatable)
    -n, --dry-run           Print manifest to stdout, do not write files
        --apply             Apply manifest to Flox environment via flox edit (validated, atomic)
    -d, --dir DIR           Target Flox environment directory (with --apply)
    -o, --output DIR        Output directory for bare manifest file (default: ./)
    -f, --force             Overwrite existing manifest without confirmation
        --validate          Verify package mappings via flox search
        --services MODE     Service handling: flox | compose | container | prompt
                            (default: prompt if TTY, container otherwise)
        --pip MODE          Python package handling: project | flox | cuda | requirements
                            (default: project)
        --verbose           Show mapping decisions on stderr
    -h, --help              Show this help

ENVIRONMENT VARIABLES:
    DOCK2FLOX_SERVICES      Override service mode (flox|container|prompt)
    DOCK2FLOX_PIP           Override pip mode (project|flox|cuda|requirements)
    DOCK2FLOX_VERBOSE       Set to 1 for verbose output

EXAMPLES:
    dock2flox --dry-run Dockerfile      # Preview the generated manifest
    dock2flox --apply Dockerfile        # Apply to current Flox environment (requires flox init)
    dock2flox --apply -d ./proj Dockerfile  # Apply to a specific Flox environment
    dock2flox --dry-run --validate .    # Preview with package validation
    dock2flox -o ./myproject Dockerfile docker-compose.yml

EOF
}

main() {
    local -a input_files=()
    local output_dir="."
    local dry_run=0
    local force=0
    local validate=0
    local opt_services=""
    local services_mode=""
    local opt_pip=""
    local pip_mode=""
    local apply=0
    local apply_dir=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -i|--input)
                input_files+=("$2")
                shift 2
                ;;
            -o|--output)
                output_dir="$2"
                shift 2
                ;;
            -n|--dry-run)
                dry_run=1
                shift
                ;;
            -f|--force)
                force=1
                shift
                ;;
            --apply)
                apply=1
                shift
                ;;
            -d|--dir)
                apply_dir="$2"
                shift 2
                ;;
            --validate)
                validate=1
                shift
                ;;
            --services)
                opt_services="$2"
                shift 2
                ;;
            --pip)
                opt_pip="$2"
                shift 2
                ;;
            --verbose)
                export DOCK2FLOX_VERBOSE=1
                shift
                ;;
            -h|--help)
                usage
                return 0
                ;;
            --)
                shift
                input_files+=("$@")
                break
                ;;
            -*)
                log_error "Unknown option: $1"
                usage
                return 1
                ;;
            *)
                input_files+=("$1")
                shift
                ;;
        esac
    done

    # Validate flag combinations
    if [[ "$apply" -eq 1 && "$dry_run" -eq 1 ]]; then
        log_error "--apply and --dry-run are mutually exclusive"
        return 1
    fi
    if [[ "$apply" -eq 1 && "$output_dir" != "." ]]; then
        log_error "--apply and -o are mutually exclusive (--apply writes via flox edit)"
        return 1
    fi

    # Determine service mode
    if [[ -n "${DOCK2FLOX_SERVICES:-}" ]]; then
        services_mode="$DOCK2FLOX_SERVICES"
    elif [[ -n "$opt_services" ]]; then
        services_mode="$opt_services"
    elif dock2flox_is_interactive; then
        services_mode="prompt"
    else
        services_mode="container"
    fi
    export DOCK2FLOX_SERVICES_MODE="$services_mode"

    # Determine pip mode
    if [[ -n "${DOCK2FLOX_PIP:-}" ]]; then
        pip_mode="$DOCK2FLOX_PIP"
    elif [[ -n "$opt_pip" ]]; then
        pip_mode="$opt_pip"
    else
        pip_mode="project"
    fi
    export DOCK2FLOX_PIP_MODE="$pip_mode"

    # Auto-detect inputs if none specified
    if [[ ${#input_files[@]} -eq 0 ]]; then
        local detected
        detected=$(dock2flox_detect_inputs ".")
        if [[ -z "$detected" ]]; then
            log_error "No Dockerfile or Compose files found in current directory"
            log_error "Specify input files explicitly: dock2flox <file>..."
            return 1
        fi
        while IFS= read -r f; do
            input_files+=("$f")
        done <<< "$detected"
        log_info "Auto-detected: ${input_files[*]}"
    fi

    # Validate inputs exist
    local f
    for f in "${input_files[@]}"; do
        if [[ ! -f "$f" ]]; then
            log_error "File not found: $f"
            return 1
        fi
    done

    # Create IR file
    local ir_file
    ir_file=$(dock2flox_mktemp)

    # Process each input file
    for f in "${input_files[@]}"; do
        local input_type
        input_type=$(dock2flox_classify_input "$f")

        case "$input_type" in
            dockerfile)
                parse_dockerfile "$f" "$ir_file"
                ;;
            compose)
                if declare -f parse_compose > /dev/null 2>&1; then
                    parse_compose "$f" "$ir_file"
                else
                    log_warn "Compose parser not available, skipping: $f"
                fi
                ;;
            devcontainer)
                if declare -f parse_devcontainer > /dev/null 2>&1; then
                    parse_devcontainer "$f" "$ir_file"
                else
                    log_warn "Devcontainer parser not available, skipping: $f"
                fi
                ;;
            *)
                log_warn "Unknown file type, skipping: $f"
                ;;
        esac
    done

    # Validate if requested
    if [[ "$validate" -eq 1 ]]; then
        if declare -f validate_ir > /dev/null 2>&1; then
            log_info "Validating package mappings via flox search..."
            validate_ir "$ir_file"
        else
            log_warn "--validate requested but validator not available"
        fi
    fi
    export DOCK2FLOX_VALIDATED="$validate"

    # Emit TOML
    if [[ "$dry_run" -eq 1 ]]; then
        emit_toml "$ir_file"
        _print_summary "$ir_file"
    elif [[ "$apply" -eq 1 ]]; then
        if ! command -v flox &>/dev/null; then
            log_error "--apply requires flox in PATH"
            return 1
        fi

        local tmp_manifest
        tmp_manifest=$(dock2flox_mktemp)
        emit_toml "$ir_file" > "$tmp_manifest"

        local -a flox_edit_args=(-f "$tmp_manifest")
        [[ -n "$apply_dir" ]] && flox_edit_args+=(-d "$apply_dir")

        log_info "Applying manifest via flox edit..."
        if flox edit "${flox_edit_args[@]}"; then
            log_info "Manifest applied successfully"
        else
            log_error "flox edit failed — manifest unchanged. Review the error above."
            log_error "Use --dry-run to inspect the generated manifest."
            return 1
        fi
        _print_summary "$ir_file"
    else
        local output_file="$output_dir/manifest.toml"
        local tmp_manifest
        tmp_manifest=$(dock2flox_mktemp)

        # Ensure output directory exists before rendering/writing.
        mkdir -p "$output_dir"
        emit_toml "$ir_file" > "$tmp_manifest"

        # Idempotent default: an existing identical manifest is a successful
        # no-op. A differing manifest still requires --force or interactive
        # confirmation so unattended runs do not clobber local edits.
        if [[ -f "$output_file" && "$force" -eq 0 ]]; then
            if cmp -s "$tmp_manifest" "$output_file"; then
                log_info "Unchanged: $output_file"
                _print_summary "$ir_file"
                return 0
            fi

            if dock2flox_is_interactive; then
                if ! dock2flox_prompt_yesno "Overwrite existing $output_file?" "n"; then
                    log_info "Aborted. Use --dry-run to preview or --force to overwrite."
                    return 0
                fi
            else
                log_error "File exists and differs: $output_file (use --force to overwrite)"
                return 1
            fi
        fi

        mv "$tmp_manifest" "$output_file"
        log_info "Wrote: $output_file"

        # Print summary
        _print_summary "$ir_file"
    fi
}

_grep_count() {
    local pattern="$1" file="$2"
    local count
    count=$(grep -c -- "$pattern" "$file" 2>/dev/null || true)
    count="${count:-0}"
    # grep -c prints exactly one integer; guard against unexpected noise before
    # using the value in arithmetic contexts.
    case "$count" in
        ''|*[!0-9]*) printf '0' ;;
        *) printf '%s' "$count" ;;
    esac
}

_print_summary() {
    local ir_file="$1"

    local n_install n_var n_hook n_service n_skip n_unmapped n_non_exact
    n_install=$(_grep_count "^INSTALL${IR_DELIM}" "$ir_file")
    n_var=$(_grep_count "^VAR${IR_DELIM}" "$ir_file")
    n_hook=$(_grep_count "^HOOK${IR_DELIM}" "$ir_file")
    n_service=$(_grep_count "^SERVICE${IR_DELIM}" "$ir_file")
    n_skip=$(_grep_count "^SKIP${IR_DELIM}" "$ir_file")
    n_unmapped=$(_grep_count 'UNMAPPED' "$ir_file")

    # Count packages that passed heuristic mapping but aren't confirmed
    local n_exact
    n_exact=$(_grep_count "${IR_DELIM}EXACT${IR_DELIM}" "$ir_file")
    n_non_exact=$((n_install - n_exact))

    log_info "Summary: ${n_install} packages, ${n_var} vars, ${n_hook} hook lines, ${n_service} services, ${n_skip} skipped"
    if [[ "$n_unmapped" -gt 0 ]]; then
        log_warn "${n_unmapped} package(s) could not be mapped — search for UNMAPPED in output"
    fi
    if [[ "$n_non_exact" -gt 0 && "${DOCK2FLOX_VALIDATED:-0}" != "1" ]]; then
        log_warn "${n_non_exact} package(s) mapped heuristically — run with --validate to verify against the Flox catalog"
    fi
}

# --- Run ---
main "$@"
